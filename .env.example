# ─── Web App (apps/web) ───
WEB_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/draw
WEB_AUTH_SECRET=your-secret-key-at-least-32-characters-long
WEB_AUTH_URL=http://localhost:3000
WEB_SMTP_HOST=smtp.example.com
WEB_SMTP_USERNAME=your-smtp-username
WEB_SMTP_PASSWORD=your-smtp-password
WEB_SMTP_MAIL_FROM=noreply@example.com

# Next.js client-side (NEXT_PUBLIC_ prefix required by Next.js)
NEXT_PUBLIC_SOCKET_URL=http://localhost:3001

# ─── Socket Server (apps/socket) ───
SOCKET_PORT=3001
SOCKET_CORS_ORIGIN=http://localhost:3000
SOCKET_AUTH_URL=http://localhost:3000
