{
  "name": "draw",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --filter web dev & pnpm --filter @draw/socket dev",
    "dev:web": "pnpm --filter web dev",
    "dev:socket": "pnpm --filter @draw/socket dev",
    "build": "pnpm -r build",
    "lint": "pnpm --filter web lint",
    "prettier:write": "prettier --write .",
    "prettier:check": "prettier --check .",
    "db:push": "pnpm --filter web db:push",
    "db:generate": "pnpm --filter web db:generate",
    "db:migrate": "pnpm --filter web db:migrate",
    "db:studio": "pnpm --filter web db:studio"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "^5"
  }
}
